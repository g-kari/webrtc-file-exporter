    "check": "tsc --noEmit && biome check ./src"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.3",
    "wrangler": "^4.74.0"
  },
  "overrides": {
    "undici": "^7.24.4"
  }
}
